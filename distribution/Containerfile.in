FROM registry.access.redhat.com/ubi9/python-312@sha256:95ec8d3ee9f875da011639213fd254256c29bc58861ac0b11f290a291fa04435
WORKDIR /opt/app-root

RUN pip install uv
RUN pip install sqlalchemy # somehow sqlalchemy[asyncio] is not sufficient
RUN uv pip install opentelemetry-distro
RUN uv pip install structlog zstandard # core ogx deps not covered by provider deps

{dependencies}
{ogx_install_source}

RUN set -o pipefail && opentelemetry-bootstrap -a requirements | uv pip install --requirement -

RUN mkdir -p ${HOME}/.ogx ${HOME}/.cache

# Pre-cache tiktoken cl100k_base encoding to avoid runtime download
# from openaipublic.blob.core.windows.net (used by vector_store chunking)
RUN uv pip install tiktoken==0.12.0
ENV TIKTOKEN_CACHE_DIR="${HOME}/.cache/tiktoken"
RUN python3 -c "import tiktoken; tiktoken.get_encoding('cl100k_base')"

COPY distribution/config.yaml ${APP_ROOT}/config.yaml
COPY --chmod=755 distribution/entrypoint.sh ${APP_ROOT}/entrypoint.sh

#TODO: remove this once we have a stable version of ogx
# OGX server version is not aligned with the client version, so we disable the version check
ENV OGX_DISABLE_VERSION_CHECK=true

ENTRYPOINT [ "/opt/app-root/entrypoint.sh" ]
